# Database
DATABASE_URL=sqlite:///./ims.db

# JWT Secret (auto-generated if not set)
SECRET_KEY=

# Debug mode (enables /docs, CORS *)
DEBUG=True

# Upload directory
UPLOAD_DIR=uploads

# Max upload size in MB
MAX_UPLOAD_SIZE_MB=100

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=

# Timezone
APP_TIMEZONE=Asia/Jerusalem

# AI / LLM Providers
DEEPSEEK_API_KEY=
GOOGLE_API_KEY=

# Google OAuth Client ID
GOOGLE_CLIENT_ID=

# Admin emails (comma-separated, auto-promoted)
ADMIN_EMAILS=

# Runtime mode: "local" or "cloud"
RUNTIME_MODE=cloud

# Local mode: comma-separated paths to watch
LOCAL_WATCH_PATHS=

# Media processing
WHISPER_API_URL=
VISION_PROVIDER=gemini

# Bridge API (cross-system)
BRIDGE_API_KEY=
SMART_DMS_URL=
SMART_DMS_BRIDGE_KEY=
